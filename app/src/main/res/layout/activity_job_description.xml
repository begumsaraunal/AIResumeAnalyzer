<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Resume Analyzer"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:textColor="@color/text_primary"/>


        <!-- ICON -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="28dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="6dp"
                android:background="@drawable/icon_container"
                android:padding="18dp"
                android:elevation="6dp"
                android:src="@drawable/outline_file_copy_24"
                android:tint="@color/primary"/>

        </LinearLayout>


        <!-- TITLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analyze Your Match"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginTop="20dp"
            android:textColor="@color/text_primary"/>


        <!-- SUBTITLE -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paste the job details below to see how your skills and experience stack up against the role."
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"/>


        <!-- LABEL -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Job Description"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:textColor="@color/text_primary"/>


        <!-- INPUT CARD -->

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:background="@color/border"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:orientation="vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                   app:boxStrokeColor="@color/primary"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/jobInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="200dp"
                        android:padding="18dp"
                        android:scrollbars="vertical"
                        android:hint="Paste job title, responsibilities, and requirements here..."
                        android:overScrollMode="always"
                        android:gravity="top|start"
                        android:inputType="textMultiLine"
                        android:background="@android:color/transparent"
                        android:textColor="@color/text_primary"/>

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/wordCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 20 words"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:layout_gravity="end"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>


        <!-- BUTTON -->

        <Button
            android:id="@+id/continueButton"
            android:enabled="false"
            android:alpha="0.4"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continue"
            android:layout_marginTop="24dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@color/primary"/>


        <!-- FOOTER -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="By continuing, you agree to our terms and privacy policy regarding data analysis."
            android:textSize="11sp"
            android:textAlignment="center"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_secondary"/>

    </LinearLayout>

</ScrollView>
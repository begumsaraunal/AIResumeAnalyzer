<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- SCROLLABLE CONTENT -->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/infoText"
        tools:ignore="NotSibling">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- HEADER -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="@android:color/transparent"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI Analysis"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- SPINNER AREA -->

            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/loadingSpinner"
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:indeterminate="false"
                    android:max="100"
                    app:indicatorColor="@color/primary"
                    app:indicatorDirectionCircular="clockwise"
                    app:indicatorInset="0dp"
                    app:indicatorSize="180dp"
                    app:trackColor="@color/border"
                    app:trackThickness="10dp" />

                <LinearLayout
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:layout_gravity="center"
                    android:background="@drawable/icon_container"
                    android:elevation="2dp"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/loadingIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/sparkle"
                        app:tint="@color/primary" />
                </LinearLayout>

                <TextView
                    android:id="@+id/loadingPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/percent_badge"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="0%"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </FrameLayout>


            <!-- STATUS -->

            <TextView
                android:id="@+id/loadingTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Analyzing your resume..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:textColor="@color/text_primary"/>

            <TextView
                android:id="@+id/loadingSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Our AI is matching your experience with the job requirements."
                android:textSize="14sp"
                android:textAlignment="center"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"/>

            <!-- PROGRESS BAR -->

            <ProgressBar
                android:id="@+id/loadingProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:progressDrawable="@drawable/rounded_progress"
                android:progressTint="@color/primary"
                android:layout_marginTop="20dp"
                android:max="100"/>

            <!-- TASK LIST -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="30dp">

                <!-- TASK 1 -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/border"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/taskUploadIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⌛"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/taskUpload"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Resume uploading"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/taskUploadStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="In progress"
                                android:textColor="@color/primary"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- TASK 2 -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/border"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/taskExtractIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⌛"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/taskExtract"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Extracting skills"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/taskExtractStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="In progress"
                                android:textColor="@color/primary"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- TASK 3 -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/primary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/border"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/taskScoreIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⌛"
                            android:textSize="18sp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/taskScore"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Calculating ATS score"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/taskScoreStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- INFO CARD -->

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/border"
                    android:padding="12dp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        android:tint="@color/primary"/>

                    <TextView
                        android:id="@+id/infoText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Higher ATS scores increase your chances of getting noticed by recruiters."
                        android:textSize="12sp"
                        android:layout_marginStart="6dp"
                        android:textColor="@color/text_secondary"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>